# Server
PORT=3003
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# PostgreSQL (use PGHOST=db when running via docker-compose)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password_here
PGDATABASE=sdl_db

# Auth
TOKEN_KEY=your_jwt_secret_here

# Seed script (optional)
SEED_ADMIN_EMAIL=admin@smsolutions.co.ke
SEED_ADMIN_PASSWORD=Admin123!

# Email notifications (Truehost cPanel — create accounts in cPanel → Email Accounts)
# Webmail: https://smsolutions.co.ke:2096  |  cPanel: https://smsolutions.co.ke:2083
MAIL_HOST=mail.smsolutions.co.ke
MAIL_PORT=465
MAIL_USERNAME=info@smsolutions.co.ke
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_NAME=Strong's Digital Labs
MAIL_FROM_ADDRESS=info@smsolutions.co.ke
# Alternative SMTP: port 587 with MAIL_ENCRYPTION=tls (secure=false in nodemailer)
